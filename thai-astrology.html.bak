function calculateLagna() {
  const birthDateVal = document.getElementById('birthDate').value;
  const birthTimeVal = document.getElementById('birthTime').value;
  
  if (!birthDateVal || !birthTimeVal) {
    alert('กรุณากรอกข้อมูลวันเกิดและเวลาเกิดให้ครบถ้วน');
    return;
  }
  
  const date = new Date(birthDateVal);
  const [hour, minute] = birthTimeVal.split(':').map(Number);
  
  const day = date.getDate();
  const month = date.getMonth() + 1; // 1-12
  const year = date.getFullYear(); // 2024
  
  // Calculate using real Thai Astrology Ephemeris
  const result = window.ThaiAstrology.calculateAllPositions({
    day: day,
    monthTh: month, 
    yearBe: year + 543,
    yearBc: year,
    hour: hour,
    minute: minute,
    province: 'Bangkok'
  });
  
  // ---------------------------------------------------------
  // GENERATE AUTHENTIC CIRCULAR THAI ZODIAC CHART (SVG)
  // ---------------------------------------------------------
  
  // พิกัดจุดกึ่งกลางของช่องด้านในสำหรับวางดวงดาว (คำนวณจาก Center of Gravity)
  const innerCoords = [
    {x: 200, y: 110}, // 0: Aries
    {x: 140, y: 108}, // 1: Taurus
    {x: 108, y: 140}, // 2: Gemini
    {x: 110, y: 200}, // 3: Cancer
    {x: 108, y: 260}, // 4: Leo
    {x: 140, y: 292}, // 5: Virgo
    {x: 200, y: 290}, // 6: Libra
    {x: 260, y: 292}, // 7: Scorpio
    {x: 292, y: 260}, // 8: Sagittarius
    {x: 290, y: 200}, // 9: Capricorn
    {x: 292, y: 140}, // 10: Aquarius
    {x: 260, y: 108}  // 11: Pisces
  ];

  // พิกัดและการหมุนของชื่อราศีกรอบนอก (คำนวณตามองศาโค้งเพื่อให้ขนานกับขอบเป๊ะๆ)
  const wedgeLabels = [
    { text: 'เมษ (๓)', color: '#eeb3b9', tx: 200, ty: 35, rot: 0 },
    { text: 'พฤษภ (๖)', color: '#fcf2b6', tx: 119, ty: 56, rot: -29.5 },
    { text: 'มิถุน (๔)', color: '#e1e6db', tx: 56, ty: 119, rot: -60.5 },
    { text: 'กรกฎ (๒)', color: '#adcbed', tx: 35, ty: 200, rot: -90 },
    { text: 'สิงห์ (๑)', color: '#eeb3b9', tx: 56, ty: 281, rot: 60.5 },
    { text: 'กันย์ (๔)', color: '#fcf2b6', tx: 119, ty: 344, rot: 29.5 },
    { text: 'ตุลย์ (๖)', color: '#e1e6db', tx: 200, ty: 365, rot: 0 },
    { text: 'พิจิก (๓)', color: '#adcbed', tx: 281, ty: 344, rot: -29.5 },
    { text: 'ธนู (๕)', color: '#eeb3b9', tx: 344, ty: 281, rot: -60.5 },
    { text: 'มังกร (๗)', color: '#fcf2b6', tx: 365, ty: 200, rot: 90 },
    { text: 'กุมภ์ (๘)', color: '#e1e6db', tx: 344, ty: 119, rot: 60.5 },
    { text: 'มีน (๕)', color: '#adcbed', tx: 281, ty: 56, rot: 29.5 }
  ];

  let textElements = wedgeLabels.map(l => 
    `<text x="${l.tx}" y="${l.ty}" transform="rotate(${l.rot}, ${l.tx}, ${l.ty})" text-anchor="middle" dominant-baseline="middle" font-size="14" font-weight="bold" fill="#2c3e50" font-family="Sarabun, sans-serif">${l.text}</text>`
  ).join('');

  let planetElements = '';
  const outputs = result.channelOutputs;
  for(let i=0; i<12; i++) {
    const text = outputs[i];
    if(text) {
      let innerSvgText = text.replace(/ลั/g, '<tspan fill="#e07a5f">ลั</tspan>');
      const pos = innerCoords[i];
      planetElements += `<text x="${pos.x}" y="${pos.y}" text-anchor="middle" dominant-baseline="middle" font-size="20" font-weight="bold" fill="#2c3e50" font-family="Sarabun, sans-serif">${innerSvgText}</text>`;
    }
  }

  const svgContent = `
    <svg viewBox="0 0 400 400" width="100%" height="auto" style="filter: drop-shadow(0 4px 12px rgba(0,0,0,0.08)); background: var(--white); border-radius: 50%;">
      <defs>
        <clipPath id="donut-clip">
          <path d="M 200 10 A 190 190 0 1 0 200 390 A 190 190 0 1 0 200 10 Z M 200 60 A 140 140 0 1 1 200 340 A 140 140 0 1 1 200 60 Z" clip-rule="evenodd" />
        </clipPath>
        <clipPath id="circle-clip">
          <circle cx="200" cy="200" r="190" />
        </clipPath>
      </defs>

      <g clip-path="url(#donut-clip)">
        <rect x="160" y="0" width="80" height="200" fill="#eeb3b9" />
        <polygon points="160,160 160,0 0,0" fill="#fcf2b6" />
        <polygon points="160,160 0,0 0,160" fill="#e1e6db" />
        <rect x="0" y="160" width="200" height="80" fill="#adcbed" />
        <polygon points="160,240 0,240 0,400" fill="#eeb3b9" />
        <polygon points="160,240 0,400 160,400" fill="#fcf2b6" />
        <rect x="160" y="200" width="80" height="200" fill="#e1e6db" />
        <polygon points="240,240 240,400 400,400" fill="#adcbed" />
        <polygon points="240,240 400,400 400,240" fill="#eeb3b9" />
        <rect x="200" y="160" width="200" height="80" fill="#fcf2b6" />
        <polygon points="240,160 400,160 400,0" fill="#e1e6db" />
        <polygon points="240,160 400,0 240,0" fill="#adcbed" />
      </g>

      <circle cx="200" cy="200" r="190" fill="none" stroke="#2c3e50" stroke-width="2.5" />
      <circle cx="200" cy="200" r="140" fill="none" stroke="#2c3e50" stroke-width="2.5" />

      <g clip-path="url(#circle-clip)">
        <line x1="160" y1="0" x2="160" y2="400" stroke="#2c3e50" stroke-width="2" />
        <line x1="240" y1="0" x2="240" y2="400" stroke="#2c3e50" stroke-width="2" />
        <line x1="0" y1="160" x2="400" y2="160" stroke="#2c3e50" stroke-width="2" />
        <line x1="0" y1="240" x2="400" y2="240" stroke="#2c3e50" stroke-width="2" />
        
        <line x1="160" y1="160" x2="0" y2="0" stroke="#2c3e50" stroke-width="2" />
        <line x1="240" y1="160" x2="400" y2="0" stroke="#2c3e50" stroke-width="2" />
        <line x1="160" y1="240" x2="0" y2="400" stroke="#2c3e50" stroke-width="2" />
        <line x1="240" y1="240" x2="400" y2="400" stroke="#2c3e50" stroke-width="2" />
      </g>

      ${textElements}
      ${planetElements}

      <text x="200" y="193" text-anchor="middle" font-size="22" font-weight="bold" fill="#d4af37" font-family="Sarabun, sans-serif">ดวงชะตา</text>
      <text x="200" y="215" text-anchor="middle" font-size="12" fill="#7f8c8d" font-family="Sarabun, sans-serif">(ดวงจักราศี)</text>
    </svg>
  `;

  document.getElementById('svgChartContainer').innerHTML = svgContent;
  
  const zodiacNames = [
    'เมษ', 'พฤษภ', 'เมถุน', 'กรกฎ', 'สิงห์', 'กันย์',
    'ตุลย์', 'พิจิก', 'ธนู', 'มังกร', 'กุมภ์', 'มีน'
  ];
  
  // result.positions.ascendant maps 0=Aries, 1=Taurus
  const lagnaZodiac = zodiacNames[result.positions.ascendant];
  
  document.getElementById('resultTitle').textContent = `ลัคนาสถิตราศี${lagnaZodiac}`;
  document.getElementById('resultDesc').innerHTML = `
    <strong>ลัคนาของคุณสถิตอยู่ในราศี${lagnaZodiac}</strong><br>
    คำนวณตำแหน่งดวงดาวและผูกดวงชะตาจริงตามหลักโหราศาสตร์ไทย (ระบบสุริยยาตร์) ด้วยเวลาเกิด ${hour.toString().padStart(2, '0')}:${minute.toString().padStart(2, '0')} น.
  `;
  
  document.getElementById('lagnaResult').style.display = 'grid';
  document.getElementById('lagnaResult').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function selectUbakong(dayIdx) {
  // Update active buttons
  for(let i=0; i<7; i++) {
    document.getElementById(`ub-${i}`).classList.toggle('active', i === dayIdx);
  }
  
  const grid = document.getElementById('ubakongGrid');
  const dayData = UBAKONG_DATA[dayIdx];
  
  // Get current time to highlight current time slot if matching
  const now = new Date();
  const currentHour = now.getHours();
  const currentMin = now.getMinutes();
  const currentVal = currentHour * 60 + currentMin;
  
  grid.innerHTML = dayData.map((slot, idx) => {
    let isActive = false;
    // Check slot bounds
    if (idx === 0 && currentVal >= 360 && currentVal < 504) isActive = true;
    else if (idx === 1 && currentVal >= 504 && currentVal < 648) isActive = true;
    else if (idx === 2 && currentVal >= 648 && currentVal < 792) isActive = true;
    else if (idx === 3 && currentVal >= 792 && currentVal < 936) isActive = true;
    else if (idx === 4 && currentVal >= 936 && currentVal < 1080) isActive = true;
    
    // Format dots color
    let dotsColor = '#4caf50'; // green for good
    if (slot.dots.includes('✕')) dotsColor = 'var(--gray-500)';
    else if (slot.dots.length <= 2) dotsColor = '#ff9800'; // orange
    else dotsColor = 'var(--gold-bright)'; // gold/yellow
    
    return `
      <div class="ubakong-cell ${isActive ? 'active' : ''}">
        <h4>${slot.name}</h4>
        <div class="ubakong-dots" style="color: ${dotsColor}">${slot.dots}</div>
        <div class="ubakong-desc">${slot.desc}</div>
      </div>
    `;
  }).join('');
}

// Init Ubakong on page load using today's day of week
document.addEventListener('DOMContentLoaded', () => {
  const today = new Date().getDay(); // 0 = Sun, 6 = Sat
  selectUbakong(today);
});
</script>

