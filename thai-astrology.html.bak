<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>โหราศาสตร์ไทย – ซินแสหวาง</title>
  <meta name="description" content="คำนวณลัคนา ดูฤกษ์มงคล และศึกษายามอุบากองตามหลักโหราศาสตร์ไทยโบราณ โดยซินแสหวาง" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Thai:wght@300;400;600;700;900&family=Noto+Sans+Thai:wght@300;400;500;600&family=Ma+Shan+Zheng&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="css/style.css?v=12" />
  <style>
    .page-hero { background:var(--grad-hero); padding:calc(var(--nav-h) + 3rem) 0 3rem; text-align:center; }
    .thai-calculator { background:var(--white); border:1px solid var(--border); border-radius:var(--r-xl); padding:var(--sp-2xl); margin:var(--sp-3xl) 0; }
    
    .chart-container {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: var(--sp-2xl);
      align-items: center;
      margin-top: var(--sp-xl);
    }
    
    /* Standard Thai Rasi Chart (ดวงจักราศี 12 ช่อง) */
    .rasi-chart {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(4, 1fr);
      width: 100%;
      max-width: 340px;
      aspect-ratio: 1 / 1;
      margin: 0 auto;
      border: 3px double var(--gold-deep);
      background: var(--cream);
      border-radius: 6px;
    }
    .rasi-box {
      border: 1px solid var(--gold);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
    }
    .rasi-center {
      grid-column: 2 / 4;
      grid-row: 2 / 4;
      border: 1px solid var(--gold);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: var(--font-serif);
      font-size: 1.3rem;
      color: var(--gold-deep);
      background: var(--white);
    }
    .zodiac-label {
      position: absolute;
      top: 4px;
      left: 4px;
      font-size: 0.65rem;
      color: var(--gray-400);
      line-height: 1;
    }
    .planet-list {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
      justify-content: center;
      font-weight: bold;
      color: var(--charcoal);
      font-size: 1rem;
    }
    
    /* Ubakong Section */
    .ubakong-container {
      background: var(--charcoal-mid);
      color: var(--cream);
      border-radius: var(--r-xl);
      padding: var(--sp-2xl);
      margin: var(--sp-3xl) 0;
    }
    .ubakong-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: var(--sp-sm);
      margin-top: var(--sp-lg);
    }
    .ubakong-cell {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--r-md);
      padding: var(--sp-md);
      text-align: center;
      transition: all var(--t-fast);
    }
    .ubakong-cell.active {
      border-color: var(--gold-bright);
      background: rgba(201,146,42,0.15);
      box-shadow: var(--shadow-glow);
    }
    .ubakong-cell h4 { font-size: 0.8rem; color: var(--gold-light); margin-bottom: var(--sp-xs); }
    .ubakong-dots { font-size: 1.5rem; color: var(--gold-bright); line-height: 1; margin: var(--sp-xs) 0; }
    .ubakong-desc { font-size: 0.75rem; color: var(--gray-300); }
    
    .day-selector {
      display: flex;
      justify-content: center;
      gap: var(--sp-sm);
      margin-bottom: var(--sp-lg);
      flex-wrap: wrap;
    }
    .day-btn {
      padding: 0.4rem 1rem;
      border-radius: var(--r-full);
      font-size: 0.85rem;
      font-weight: 600;
      border: 1px solid rgba(255,255,255,0.2);
      color: var(--cream);
      transition: all var(--t-fast);
    }
    .day-btn.active, .day-btn:hover {
      background: var(--gold);
      border-color: var(--gold);
      color: var(--charcoal);
    }
    
    .topic-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--sp-lg); }
    .topic-card { background:var(--white); border:1px solid var(--border); border-radius:var(--r-lg); padding:var(--sp-xl); transition:all var(--t-mid); }
    .topic-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-md); border-color:var(--crimson-light); }
    .topic-icon { font-size:2rem; margin-bottom:var(--sp-sm); }
    .topic-card h3 { font-family:var(--font-serif); font-size:1.05rem; font-weight:700; color:var(--charcoal); margin-bottom:var(--sp-sm); }
    .topic-card p { font-size:0.84rem; color:var(--text-secondary); line-height:1.65; }
    
    @media(max-width:768px) {
      .chart-container { grid-template-columns: 1fr; }
      .ubakong-grid { grid-template-columns: 1fr; }
      .topic-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ✦ NAVIGATION ✦ -->
<header id="navbar" class="navbar">
  <div class="nav-container">
    <a href="index.html" class="nav-logo">
      <span class="logo-zh">王</span>
      <div class="logo-text">
        <span class="logo-main">ซินแสหวาง</span>
        <span class="logo-sub">Sinsae Hwang · 星師皇</span>
      </div>
