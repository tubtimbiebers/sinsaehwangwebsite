    <nav class="nav-menu" id="navMenu">
      <a href="index.html" class="nav-link">หน้าแรก</a>
      <a href="chinese-astrology.html" class="nav-link">โหราศาสตร์จีน</a>
      <a href="thai-astrology.html" class="nav-link active">โหราศาสตร์ไทย</a>
      <a href="iching.html" class="nav-link">อี้จิง</a>
      <a href="fengshui.html" class="nav-link">ฮวงจุ้ย</a>
      <a href="lucky-colors.html" class="nav-link">คู่สีมงคล</a>
      <a href="contact.html" class="nav-link">ติดต่อ</a>
    </nav>
    <div class="nav-actions">
      <a href="consult.html" class="btn-consult">ปรึกษาซินแส</a>
      <button class="nav-toggle" id="navToggle" aria-label="เปิดเมนู">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- ✦ HERO ✦ -->
<div class="page-hero">
  <div class="container">
    <div class="section-tag" style="background:var(--cream); color:var(--charcoal); border-color:var(--gold-light);">โหราศาสตร์ไทยโบราณ</div>
    <h1 class="hero-title" style="margin-bottom:1rem; color: var(--charcoal);">
      <span class="title-zh" style="font-size:clamp(3rem,8vw,5rem);color:var(--gold-deep);opacity:0.6;">星</span>
      <span class="title-th" style="font-size:clamp(1.8rem,4vw,2.8rem);">โหราศาสตร์ไทย</span>
      <span class="title-sub" style="color:var(--text-secondary);">ลัคนา · ดาวเคราะห์นพเคราะห์ · ยามอุบากอง</span>
    </h1>
    <p style="color:var(--text-secondary);max-width:600px;margin:0 auto;font-size:1.1rem;line-height:1.6;">วิเคราะห์ดวงชะตาตามจักรราศีไทยโบราณ คำนวณลัคนา หาฤกษ์ยามมงคลเพื่อความรุ่งเรือง</p>
  </div>
</div>

<section class="section">
  <div class="container">
    
    <!-- ✦ LAGNA CALCULATOR ✦ -->
    <div class="thai-calculator">
      <h2 style="font-family:var(--font-serif);font-size:1.4rem;color:var(--charcoal);margin-bottom:var(--sp-sm);">🔮 คำนวณหาลัคนา (ดวงไทยเบื้องต้น)</h2>
      <p style="color:var(--text-secondary);font-size:0.875rem;margin-bottom:var(--sp-xl);">กรอกวันเวลาเกิดของคุณเพื่อสมผุสลัคนาในจักรราศี</p>
      
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-md);margin-bottom:var(--sp-lg);">
        <div class="form-group">
          <label style="font-size:0.8rem;font-weight:600;color:var(--gray-700);display:block;margin-bottom:4px;">วันเกิด (ค.ศ.)</label>
          <input type="date" class="form-control" id="birthDate" style="width:100%;padding:0.6rem;border:1px solid var(--border);border-radius:var(--r-md);" />
        </div>
        <div class="form-group">
          <label style="font-size:0.8rem;font-weight:600;color:var(--gray-700);display:block;margin-bottom:4px;">เวลาเกิด (น.)</label>
          <input type="time" class="form-control" id="birthTime" style="width:100%;padding:0.6rem;border:1px solid var(--border);border-radius:var(--r-md);" />
        </div>
      </div>
      
      <button class="btn-primary" onclick="calculateLagna()" id="calcBtn">คำนวณลัคนา</button>
      
      <div id="lagnaResult" class="chart-container" style="display:none;">
        <div id="svgChartContainer" style="width: 100%; max-width: 450px; margin: 0 auto;">
          <!-- SVG will be injected here -->
        </div>
        
        <div style="background:var(--cream);border-radius:var(--r-lg);padding:var(--sp-xl);border:1px solid var(--border);">
          <h3 style="font-family:var(--font-serif);font-size:1.2rem;color:var(--crimson);margin-bottom:var(--sp-sm);" id="resultTitle">ลัคนาของคุณ</h3>
          <p style="font-size:0.9rem;color:var(--text-primary);line-height:1.8;" id="resultDesc"></p>
          <div style="margin-top:var(--sp-lg);">
            <a href="consult.html" class="btn-primary" style="font-size:0.8rem;">ขอฤกษ์มงคลส่วนตัวจากซินแส</a>
          </div>
        </div>
      </div>
    </div>
    
    <!-- ✦ UBAKONG DAILY ORACLE ✦ -->
    <div class="ubakong-container">
      <h2 style="font-family:var(--font-serif);font-size:1.4rem;text-align:center;margin-bottom:var(--sp-sm);color:var(--gold-bright);">🧭 ยามอุบากอง (ยามสามตาโบราณ)</h2>
      <p style="text-align:center;color:var(--gray-300);font-size:0.875rem;margin-bottom:var(--sp-xl);">เลือกวันสำคัญในการเดินทาง เจรจาธุรกิจ หรือริเริ่มงานใหญ่ เพื่อเลือกยามมงคลที่ดีที่สุด</p>
      
      <div class="day-selector">
        <button class="day-btn active" onclick="selectUbakong(0)" id="ub-0">วันอาทิตย์</button>
        <button class="day-btn" onclick="selectUbakong(1)" id="ub-1">วันจันทร์</button>
        <button class="day-btn" onclick="selectUbakong(2)" id="ub-2">วันอังคาร</button>
        <button class="day-btn" onclick="selectUbakong(3)" id="ub-3">วันพุธ</button>
        <button class="day-btn" onclick="selectUbakong(4)" id="ub-4">วันพฤหัสบดี</button>
        <button class="day-btn" onclick="selectUbakong(5)" id="ub-5">วันศุกร์</button>
        <button class="day-btn" onclick="selectUbakong(6)" id="ub-6">วันเสาร์</button>
      </div>
      
      <div class="ubakong-grid" id="ubakongGrid">
        <!-- populated by JS -->
      </div>
      
      <div style="margin-top:var(--sp-lg);font-size:0.75rem;color:var(--gray-400);text-align:center;">
        หมายเหตุ: ยามอุบากองเป็นหลักสถิติยามโบราณ นิยมใช้เป็นหลักการตัดสินใจเดินทางเบื้องต้น
      </div>
    </div>
    
    <!-- ✦ TOPICS ✦ -->
    <div class="section-header">
      <div class="section-tag">ความรู้โหราศาสตร์ไทย</div>
      <h2 class="section-title">หัวข้อสำคัญ<span>ของดวงไทย</span></h2>
    </div>
    
    <div class="topic-grid">
      <div class="topic-card">
        <div class="topic-icon">🪐</div>
        <h3>ดาวนพเคราะห์ทั้ง ๙</h3>
        <p>วิเคราะห์อิทธิพลของเทวดานพเคราะห์ ตั้งแต่พระอาทิตย์ (๑) ถึงพระเกตุ (๙) และดาวมฤตยู (๐) ที่ทำหน้าที่ส่งผลต่อวิถีชีวิตในแต่ละช่วงวัย</p>
      </div>
      <div class="topic-card">
        <div class="topic-icon">📅</div>
        <h3>การหาฤกษ์ยามโบราณ</h3>
        <p>ฤกษ์แต่งงาน ฤกษ์ขึ้นบ้านใหม่ ฤกษ์ออกรถใหม่ โดยใช้ดิถีมงคลกาล ฤกษ์บน-ฤกษ์ล่าง เช่น ฤกษ์ภูมิปาโล ฤกษ์มหัทธโน</p>
      </div>
      <div class="topic-card">
        <div class="topic-icon">🧿</div>
        <h3>การแก้เคล็ดและสะเดาะเคราะห์</h3>
        <p>พิธีบูชาเทวดานพเคราะห์ การทำบุญตักบาตรตามกำลังดาวนพเคราะห์เพื่อปัดเป่าอุปสรรคและเสริมดวงชะตา</p>
      </div>
    </div>
    
  </div>
</section>

