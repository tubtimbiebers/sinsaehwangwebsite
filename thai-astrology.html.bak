<script src="js/main.js"></script>
<script>
// Zodiac descriptions for Thai Astrology
const THAI_ZODIAC = [
  { name: 'เมษ (Aries)', element: 'ไฟ', trait: 'มีความเป็นผู้นำสูง กล้าหาญ มุ่งมั่นและรักการผจญภัย เสริมด้วยเครื่องประดับโทนสีแดงและทอง', stars: ['๑','๓'] },
  { name: 'พฤษภ (Taurus)', element: 'ดิน', trait: 'มั่นคง หนักแน่น มีความอดทนสูง รักสงบและชื่นชอบศิลปะ เสริมดวงด้วยสีครีมและเหลืองอ่อน', stars: ['๖','๒'] },
  { name: 'เมถุน (Gemini)', element: 'ลม', trait: 'เจรจาเก่ง เรียนรู้เร็ว ปรับตัวง่าย มีมนุษยสัมพันธ์ดี เสริมดวงด้วยสีเขียวและลายตาราง', stars: ['๔'] },
  { name: 'กรกฎ (Cancer)', element: 'น้ำ', trait: 'อ่อนโยน รักครอบครัว มีเซนส์หรือลางสังหรณ์แม่นยำสูง เสริมดวงด้วยสีขาวมุกและสีน้ำเงิน', stars: ['๒'] },
  { name: 'สิงห์ (Leo)', element: 'ไฟ', trait: 'สง่างาม กล้าหาญ มีบารมี ใจกว้างและเป็นผู้นำที่ดี เสริมดวงด้วยสีทองและส้มสว่าง', stars: ['๑'] },
  { name: 'กันย์ (Virgo)', element: 'ดิน', trait: 'ละเอียดรอบคอบ มีระเบียบวินัย รักความสะอาด เก่งเรื่องจัดการ เสริมดวงด้วยสีน้ำตาลและสีครีม', stars: ['๔'] },
  { name: 'ตุลย์ (Libra)', element: 'ลม', trait: 'รักความยุติธรรม มีเสน่ห์ ชอบความสุนทรีย์ รักสงบและมิตรภาพ เสริมดวงด้วยสีน้ำเงินและฟ้าอ่อน', stars: ['๖'] },
  { name: 'พิจิก (Scorpio)', element: 'น้ำ', trait: 'มีเสน่ห์ลึกลับ ใจเด็ดเดี่ยว มีสัญชาตญาณสูงและมีความสามารถเฉพาะตัว เสริมดวงด้วยสีแดงเข้มและดำ', stars: ['๓','๘'] },
  { name: 'ธนู (Sagittarius)', element: 'ไฟ', trait: 'รักอิสระ มีปัญญาความรู้ ชอบแสวงหาความจริงและชอบเดินทาง เสริมดวงด้วยสีเหลืองทองและส้ม', stars: ['๕'] },
  { name: 'มังกร (Capricorn)', element: 'ดิน', trait: 'มีความรับผิดชอบสูง มุ่งมั่น มีความอดทนและจริงจังกับเป้าหมายชีวิต เสริมดวงด้วยสีเทาและเทาเข้ม', stars: ['๗'] },
  { name: 'กุมภ์ (Aquarius)', element: 'ลม', trait: 'คิดสร้างสรรค์ มีความคิดแปลกใหม่ รักเพื่อนฝูงและอุดมการณ์ เสริมดวงด้วยสีฟ้าอมเทาและสีดำ', stars: ['๘','๗'] },
  { name: 'มีน (Pisces)', element: 'น้ำ', trait: 'มีจินตนาการสูง อ่อนโยน มีน้ำใจ ชอบช่วยเหลือผู้อื่น เสริมดวงด้วยสีเหลืองและเขียวอ่อน', stars: ['๕','๙'] }
];

const UBAKONG_DATA = [
  // Sun (0)
  [
    { name: '06:00 - 08:24', dots: '✕', desc: 'ยามปลอด: ไม่ดีไม่เสีย หลีกเลี่ยงงานสำคัญ' },
